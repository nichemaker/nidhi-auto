---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';

const products = [
  { title: 'Engine Components', desc: 'Pistons, cylinder heads, crankshafts, camshafts and valves.' },
  { title: 'Transmission Parts', desc: 'Gear shafts and clutch assemblies.' },
  { title: 'Suspension & Steering', desc: 'Tie rods, control arms and ball joints.' },
  { title: 'Sheet-Metal & Fabricated', desc: 'Brackets, mounting parts and sheet-metal parts.' },
  { title: 'Welded Assemblies', desc: 'Robust welded assemblies built for strength and reliability.' },
  { title: 'Custom Components', desc: 'Custom-engineered parts built to customer drawings.' },
];

const chips = ['All Products', 'Engine', 'Transmission', 'Suspension & Steering', 'Sheet-Metal & Fabricated', 'Welded Assemblies', 'Custom'];
---

<Layout title="Products — Nidhi Auto Components LLP" description="A broad portfolio of precision automotive components — engine, transmission, suspension/steering and sheet-metal parts, through to custom-engineered assemblies." activePage="products">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>Products</span></div>
      <h1>Product Portfolio</h1>
      <p>A broad portfolio of precision automotive components — engine, transmission, suspension/steering and sheet-metal parts, through to fully custom-engineered assemblies.</p>
    </div>
  </section>

  <section class="products">
    <div class="container">
      <div class="chips">
        {chips.map((chip, i) => (
          <span class={`chip${i === 0 ? ' active' : ''}`}>{chip}</span>
        ))}
      </div>
      <div class="prod-grid stacked">
        {products.map(product => (
          <div class="prod-card stacked">
            <div class="ph">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
              <span class="ph-label">Product Image<br/>Placeholder</span>
            </div>
            <div class="prod-info">
              <span class="prod-tag">Automotive Component</span>
              <h3>{product.title}</h3>
              <p>{product.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />

</Layout>

<script>
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });
</script>
