---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout title="About — Nidhi Auto LLP" description="A Bhiwadi-based subcontract manufacturer delivering precision-engineered automotive components." activePage="about">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>About</span></div>
      <h1>Built for Reliable Automotive Supply Chains</h1>
      <p>A Bhiwadi-based subcontract manufacturer delivering precision-engineered automotive components with consistency and trust.</p>
    </div>
  </section>

  <section class="about">
    <div class="container about-grid">
      <div class="ph about-media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V9l5 3V9l5 3V6l5 3v11"/><path d="M9 20v-4h2v4"/></svg>
        <span class="ph-label">Facility Illustration Placeholder</span>
      </div>
      <div class="about-copy">
        <p class="eyebrow">About Nidhi Auto</p>
        <h2>Precision Manufacturing You Can Rely On</h2>
        <p>Nidhi Auto LLP is a Bhiwadi-based subcontract manufacturing company specializing in precision-engineered automotive components.</p>
        <p>With a strong production capacity of 500 MT and a portfolio of 45 products, we support OEMs and Tier-1 suppliers with consistent quality, on-time delivery, and competitive solutions.</p>
        <p>Our experienced team, robust infrastructure, and process-driven approach ensure we meet the evolving needs of the automotive industry.</p>
      </div>
    </div>
  </section>

  <section class="stats-wrap" style="padding-bottom:80px">
    <div class="container">
      <div class="stats">
        <div class="stat">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg></span>
          <div><div class="stat-num">500 MT</div><div class="stat-label">Capacity</div></div>
        </div>
        <div class="stat">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg></span>
          <div><div class="stat-num">45</div><div class="stat-label">Products</div></div>
        </div>
        <div class="stat is-text">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span>
          <div><div class="stat-num">Bhiwadi,</div><div class="stat-label">Rajasthan</div></div>
        </div>
        <div class="stat is-text">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <div><div class="stat-label">Experienced</div><div class="stat-label">Team</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="sec-head"><p class="eyebrow">Our Direction</p><h2>Mission &amp; Vision</h2></div>
      <div class="feature-list">
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
          <div>
            <h3>Our Mission</h3>
            <p>To deliver dependable, precision-engineered automotive components through process-driven manufacturing, consistent quality and reliable on-time dispatch.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg></div>
          <div>
            <h3>Our Vision</h3>
            <p>To be a trusted long-term manufacturing partner for OEMs and Tier-1 suppliers, recognised for reliability, integrity and engineering discipline.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="why">
    <div class="container">
      <h2>Why Nidhi Auto</h2>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Dependable Production Capacity</h3>
          <p>500 MT capacity to handle regular and higher orders with consistency.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg></div>
          <h3>Quality-Focused Manufacturing</h3>
          <p>Process-driven approach ensuring quality at every stage.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>Bhiwadi Industrial Location</h3>
          <p>Strategic location with easy access to industrial corridors and customers.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M21 12A9 9 0 0 0 6 5.3L3 8"/><path d="M21 22v-6h-6"/><path d="M3 12a9 9 0 0 0 15 6.7l3-2.7"/></svg></div>
          <h3>Repeat Production Support</h3>
          <p>Experience in managing repeat orders with stable quality.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg></div>
          <h3>Timely Dispatch</h3>
          <p>Efficient planning and logistics for on-time deliveries.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />

</Layout>
