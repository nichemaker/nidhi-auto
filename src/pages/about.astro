---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout title="About — Nidhi Auto Components LLP" description="A Rajasthan-based precision manufacturer of engine child parts and sheet-metal components — built on CNC precision and in-house quality control." activePage="about">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>About</span></div>
      <h1>Built for Reliable Automotive Supply Chains</h1>
      <p>A Rajasthan-based precision manufacturer of engine child parts and sheet-metal components — built on CNC precision and in-house quality control.</p>
    </div>
  </section>

  <section class="about">
    <div class="container about-grid">
      <div class="ph about-media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V9l5 3V9l5 3V6l5 3v11"/><path d="M9 20v-4h2v4"/></svg>
        <span class="ph-label">Facility Illustration Placeholder</span>
      </div>
      <div class="about-copy">
        <p class="eyebrow">About Nidhi Auto</p>
        <h2>Precision Manufacturing You Can Rely On</h2>
        <p>Nidhi Auto Components LLP is a Rajasthan-based precision manufacturer of automotive components, serving OEMs, Tier-1 and Tier-2 suppliers, and aftermarket distributors across India. We manufacture engine and transmission child parts alongside sheet-metal and fabricated components — combining CNC machining and in-house design with robust, stage-by-stage quality control.</p>
        <p>A process-driven approach, modern machinery, and a skilled 40-member workforce let us deliver consistent quality, competitive pricing, and on-time dispatch.</p>
      </div>
    </div>
  </section>

  <section class="stats-wrap" style="padding-bottom:80px">
    <div class="container">
      <div class="stats">
        <div class="stat">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <div><div class="stat-num">40</div><div class="stat-label">Member Team</div></div>
        </div>
        <div class="stat">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg></span>
          <div><div class="stat-num">100 kW</div><div class="stat-label">Connected Power</div></div>
        </div>
        <div class="stat">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
          <div><div class="stat-num">365</div><div class="stat-label">Days Operations</div></div>
        </div>
        <div class="stat is-text">
          <span class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
          <div><div class="stat-num">OEM + Aftermarket</div><div class="stat-label">Markets served</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="sec-head"><p class="eyebrow">Our Direction</p><h2>Mission &amp; Vision</h2></div>
      <div class="feature-list">
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
          <div>
            <h3>Our Mission</h3>
            <p>To deliver dependable, precision-engineered automotive components through process-driven manufacturing, consistent quality and reliable on-time dispatch.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg></div>
          <div>
            <h3>Our Vision</h3>
            <p>To be a trusted long-term manufacturing partner for OEMs, Tier-1 &amp; Tier-2 suppliers, and the aftermarket, recognised for reliability, integrity and engineering discipline.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="why">
    <div class="container">
      <h2>Why Nidhi Auto</h2>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Dependable Capacity</h3>
          <p>365-day operations to handle regular and higher-volume orders with consistency.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg></div>
          <h3>Quality-Focused Manufacturing</h3>
          <p>SOP-driven manufacturing ensuring quality at every stage.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>Strategic Rajasthan Location</h3>
          <p>RIICO Khushkhera, Alwar — strategic access to industrial corridors and customers.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M21 12A9 9 0 0 0 6 5.3L3 8"/><path d="M21 22v-6h-6"/><path d="M3 12a9 9 0 0 0 15 6.7l3-2.7"/></svg></div>
          <h3>Repeat Production Support</h3>
          <p>Experience in managing repeat orders with stable quality.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg></div>
          <h3>Timely Dispatch</h3>
          <p>Efficient planning and logistics for on-time deliveries.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />

</Layout>
