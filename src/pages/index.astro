---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout title="Nidhi Auto LLP — Precision Auto Component Manufacturing in Bhiwadi" activePage="home">

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>Precision Auto Component Manufacturing in Bhiwadi</h1>
        <p class="lead">Reliable subcontract manufacturing support for automotive supply chains.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
            Request Company Profile
          </a>
          <a href="/capabilities" class="btn btn-outline">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            View Capabilities
          </a>
        </div>
      </div>
      <div class="ph hero-media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V9l5 3V9l5 3V6l5 3v11"/><path d="M9 20v-4h2v4"/></svg>
        <span class="ph-label">Factory / Production<br/>Floor Placeholder</span>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-wrap">
    <div class="container">
      <div class="stats">
        <div class="stat">
          <span class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </span>
          <div><div class="stat-num">500 MT</div><div class="stat-label">Capacity</div></div>
        </div>
        <div class="stat">
          <span class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          </span>
          <div><div class="stat-num">45</div><div class="stat-label">Products</div></div>
        </div>
        <div class="stat is-text">
          <span class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div><div class="stat-num">Bhiwadi,</div><div class="stat-label">Rajasthan</div></div>
        </div>
        <div class="stat is-text">
          <span class="stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          </span>
          <div><div class="stat-label">Automotive</div><div class="stat-label">Components</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="container about-grid">
      <div class="ph about-media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V9l5 3V9l5 3V6l5 3v11"/><path d="M7 6V3"/><path d="M9 20v-3h2v3"/></svg>
        <span class="ph-label">Facility Illustration Placeholder</span>
      </div>
      <div class="about-copy">
        <p class="eyebrow">About Nidhi Auto</p>
        <h2>Built for Reliable Automotive Supply Chains</h2>
        <p>Nidhi Auto LLP is a Bhiwadi-based subcontract manufacturing company specializing in precision-engineered automotive components.</p>
        <p>With a strong production capacity of 500 MT and a portfolio of 45 products, we support OEMs and Tier-1 suppliers with consistent quality, on-time delivery, and competitive solutions.</p>
        <p>Our experienced team, robust infrastructure, and process-driven approach ensure we meet the evolving needs of the automotive industry.</p>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="capabilities" id="capabilities">
    <div class="container">
      <div class="sec-head"><p class="eyebrow">Our Capabilities</p></div>
      <div class="cap-grid">
        <div class="cap-card">
          <div class="cap-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg></div>
          <h3>Sheet Metal Components</h3>
          <div class="rule"></div>
          <p>Precision sheet metal parts manufactured to strict tolerances.</p>
        </div>
        <div class="cap-card">
          <div class="cap-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
          <h3>Fabricated Parts</h3>
          <div class="rule"></div>
          <p>High-quality fabricated parts for diverse automotive applications.</p>
        </div>
        <div class="cap-card">
          <div class="cap-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>Welded Assemblies</h3>
          <div class="rule"></div>
          <p>Strong, reliable welded assemblies built for performance.</p>
        </div>
        <div class="cap-card">
          <div class="cap-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
          <h3>Custom Auto Components</h3>
          <div class="rule"></div>
          <p>Tailored solutions to meet specific customer requirements.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY NIDHI AUTO -->
  <section class="why">
    <div class="container">
      <h2>Why Nidhi Auto</h2>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <h3>Dependable Production Capacity</h3>
          <p>500 MT capacity to handle regular and higher orders with consistency.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg></div>
          <h3>Quality-Focused Manufacturing</h3>
          <p>Process-driven approach ensuring quality at every stage.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>Bhiwadi Industrial Location</h3>
          <p>Strategic location with easy access to industrial corridors and customers.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M21 12A9 9 0 0 0 6 5.3L3 8"/><path d="M21 22v-6h-6"/><path d="M3 12a9 9 0 0 0 15 6.7l3-2.7"/></svg></div>
          <h3>Repeat Production Support</h3>
          <p>Experience in managing repeat orders with stable quality.</p>
        </div>
        <div class="why-item">
          <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg></div>
          <h3>Timely Dispatch</h3>
          <p>Efficient planning and logistics for on-time deliveries.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 45 PRODUCT PORTFOLIO -->
  <section class="products" id="products">
    <div class="container">
      <div class="sec-head">
        <p class="eyebrow">Our Capabilities</p>
        <h2>45 Product Portfolio</h2>
      </div>
      <div class="prod-grid">
        {[
          { title: 'Brackets', desc: 'Built to brackets for various automotive applications.' },
          { title: 'Mounting Parts', desc: 'Parts for mounting units ensuring secure fit and performance.' },
          { title: 'Welded Assemblies', desc: 'Robust welded assemblies built for strength and reliability.' },
          { title: 'Sheet Metal Parts', desc: 'High-precision sheet metal components with excellent finish.' },
          { title: 'Support Components', desc: 'Reliable support components for structural and functional needs.' },
          { title: 'Custom Parts', desc: 'Custom-engineered parts as per specific customer requirements.' },
        ].map(product => (
          <div class="prod-card">
            <div class="ph sm">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
              <span class="ph-label">Product Image<br/>Placeholder</span>
            </div>
            <div class="prod-info">
              <h3>{product.title}</h3>
              <p>{product.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUALITY & PROCESS CONTROL -->
  <section class="process" id="quality">
    <div class="container">
      <p class="eyebrow">Quality &amp; Process Control</p>
      <div class="proc-track">
        <div class="proc-step">
          <div class="proc-dashes"></div>
          <div class="proc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
          <div class="proc-circle">
            <span class="proc-badge">1</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
          </div>
          <h3>Incoming Checks</h3>
          <p>Raw material verification and dimensional checks to ensure quality at the source.</p>
        </div>
        <div class="proc-step">
          <div class="proc-dashes"></div>
          <div class="proc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
          <div class="proc-circle">
            <span class="proc-badge">2</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3>In-Process Inspection</h3>
          <p>Regular process inspections and monitoring to maintain consistency and accuracy.</p>
        </div>
        <div class="proc-step">
          <div class="proc-dashes"></div>
          <div class="proc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
          <div class="proc-circle">
            <span class="proc-badge">3</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
          </div>
          <h3>Final Inspection</h3>
          <p>Comprehensive inspection for functional, performance and dimensional before dispatch.</p>
        </div>
        <div class="proc-step">
          <div class="proc-circle">
            <span class="proc-badge">4</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          </div>
          <h3>Dispatch Readiness</h3>
          <p>Secure packing and documentation to ensure safe and timely deliveries.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FACILITY & INFRASTRUCTURE -->
  <section class="facility" id="facility">
    <div class="container">
      <h2>Facility &amp; Infrastructure</h2>
      <div class="fac-grid">
        <div class="ph">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-8"/><path d="M5 20v-5"/><path d="M19 20v-3"/><rect x="3" y="4" width="6" height="6" rx="1"/><path d="M9 7h3l2 3"/><path d="M3 20h18"/></svg>
          <span class="ph-label">Machine / Press Shop<br/>Placeholder</span>
        </div>
        <div class="ph">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>
          <span class="ph-label">Inspection Area<br/>Placeholder</span>
        </div>
        <div class="ph">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
          <span class="ph-label">Dispatch Area<br/>Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaBand />

</Layout>
