---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout title="Facility — Nidhi Auto Components LLP" description="Robust infrastructure across our press shop, inspection area and dispatch — built to support reliable, repeatable production." activePage="facility">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>Facility</span></div>
      <h1>Facility &amp; Infrastructure</h1>
      <p>Robust infrastructure across our press shop, inspection area and dispatch — built to support reliable, repeatable production.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="fac-gallery">
        <div class="ph wide">
          <img
            src="https://nidhi-auto.b-cdn.net/nidhi%20auto%20pressing%20machine%20image.webp"
            alt="Power press machine in operation at Nidhi Auto Components' RIICO Khushkhera facility"
            loading="lazy"
            decoding="async"
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
          />
          <span class="ph-label" style="position:relative;z-index:1;margin-top:auto;width:100%;background:rgba(12,36,64,.65);color:#fff;padding:6px 14px;font-size:13px;">Machine / Press Shop</span>
        </div>
        <div class="ph">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span class="ph-label">Inspection Area Placeholder</span>
        </div>
        <div class="ph">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
          <span class="ph-label">Dispatch Area Placeholder</span>
        </div>
        <div class="ph wide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V9l5 3V9l5 3V6l5 3v11"/><path d="M9 20v-4h2v4"/></svg>
          <span class="ph-label">Production Floor Placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="sec-head"><p class="eyebrow">Infrastructure</p><h2>Equipped for Precision Production</h2></div>
      <div class="feature-list">
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-8"/><path d="M5 20v-5"/><path d="M19 20v-3"/><rect x="3" y="4" width="6" height="6" rx="1"/><path d="M9 7h3l2 3"/><path d="M3 20h18"/></svg></div>
          <div>
            <h3>Machine / Press Shop</h3>
            <p>CNC machining, sheet-metal forming, fabrication and welding operations.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></div>
          <div>
            <h3>Inspection Area</h3>
            <p>Dedicated space for dimensional and quality checks throughout the production cycle.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M14 9h4l4 4v4a1 1 0 0 1-1 1h-1"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg></div>
          <div>
            <h3>Dispatch Area</h3>
            <p>Organised packing and dispatch handling to support safe, on-time deliveries.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <div>
            <h3>100 kW Connected Load</h3>
            <p>Dedicated machining, inspection, and dispatch areas at our RIICO Khushkhera facility, Alwar.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />

</Layout>
