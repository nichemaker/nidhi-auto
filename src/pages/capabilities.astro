---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';

const checkIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

const capabilities = [
  {
    eyebrow: 'Capability 01',
    title: 'CNC Machining & Precision Manufacturing',
    desc: 'Precision-machined components produced on CNC equipment to strict tolerances.',
    features: ['Engine and transmission child parts', 'Tight dimensional accuracy and repeatability', 'Clean, burr-free finishing'],
    flip: false,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>`,
    phLabel: 'CNC Machining Placeholder',
  },
  {
    eyebrow: 'Capability 02',
    title: 'In-House Design & Prototyping (CAD/CAM)',
    desc: 'Component design and prototyping using CAD/CAM, from concept to production-ready parts.',
    features: ['CAD/CAM modelling and simulation', 'Rapid prototyping and design validation', 'Collaborative engineering with customers'],
    flip: true,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    phLabel: 'CAD/CAM Design Placeholder',
  },
  {
    eyebrow: 'Capability 03',
    title: 'Sheet Metal & Fabricated Parts',
    desc: 'Sheet-metal and fabricated parts for diverse automotive applications.',
    features: ['Blanking, bending and forming operations', 'Sub-assembly fabrication', 'Application-specific tooling'],
    flip: false,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    phLabel: 'Sheet Metal & Fabricated Placeholder',
  },
  {
    eyebrow: 'Capability 04',
    title: 'Quality Control & SOPs',
    desc: 'Stage-by-stage quality control governed by documented SOPs.',
    features: ['Incoming, in-process and final inspection', 'Documented standard operating procedures', 'Functional, performance and dimensional checks'],
    flip: true,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
    phLabel: 'Quality Control Placeholder',
    img: 'https://nidhi-auto.b-cdn.net/nidhi%20auto%20quality%20assurance%20section.webp',
    imgAlt: 'Quality inspection and measurement of components at Nidhi Auto Components\' RIICO Khushkhera facility',
  },
];
---

<Layout title="Capabilities — Nidhi Auto Components LLP" description="From CNC-machined engine components to sheet-metal fabrication and welded assemblies — engineered to strict tolerances for the automotive industry." activePage="capabilities">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>Capabilities</span></div>
      <h1>Our Manufacturing Capabilities</h1>
      <p>From CNC-machined engine components to sheet-metal fabrication and welded assemblies — engineered to strict tolerances for the automotive industry.</p>
    </div>
  </section>

  <section class="capabilities" style="padding-top:72px">
    <div class="container">
      <div class="cap-grid">
        {capabilities.map(cap => (
          <div class="cap-card">
            <div class="cap-icon" set:html={cap.icon}></div>
            <h3>{cap.title}</h3>
            <div class="rule"></div>
            <p>{cap.desc.split('.')[0]}.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      {capabilities.map(cap => (
        <div class={`cap-detail${cap.flip ? ' flip' : ''}`}>
          <div class="cap-detail-media">
            <div class="ph">
              {cap.img ? (
                <img src={cap.img} alt={cap.imgAlt} loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
              ) : (
                <>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
                  <span class="ph-label">{cap.phLabel}</span>
                </>
              )}
            </div>
          </div>
          <div>
            <div class="cap-icon" style="color:var(--orange);margin-bottom:6px" set:html={cap.icon}></div>
            <p class="eyebrow">{cap.eyebrow}</p>
            <h3>{cap.title}</h3>
            <p>{cap.desc}</p>
            <ul>
              {cap.features.map(f => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <CtaBand />

</Layout>
