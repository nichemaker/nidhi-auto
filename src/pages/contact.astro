---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout title="Contact — Nidhi Auto Components LLP" description="Send us your requirements or request a quote. We are here to support your manufacturing needs." activePage="contact">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>Contact</span></div>
      <h1>Get In Touch</h1>
      <p>Send us your requirements or request a quote. We are here to support your manufacturing needs.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <p class="eyebrow">Contact Details</p>
        <h2 style="font-size:28px;margin-bottom:6px">Let's Work Together</h2>
        <p style="margin-bottom:8px">Reach out for quotes, capabilities or partnership enquiries.</p>
        <div class="info-card">
          <div class="i-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <div><h4>Factory</h4><p>G1-444(B), RIICO Industrial Area, Khushkhera, Tapukara, Tijara, Alwar – 301707, Rajasthan, India</p></div>
        </div>
        <div class="info-card">
          <div class="i-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <div><h4>Registered Office</h4><p>Shop No. A-1, Ganpati Plaza, Phool Bagh, Bhiwadi – 301019, Rajasthan, India</p></div>
        </div>
        <div class="info-card">
          <div class="i-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <div><h4>Phone</h4><p>Phone Placeholder</p></div>
        </div>
        <div class="info-card">
          <div class="i-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
          <div><h4>Email</h4><p>Email Placeholder</p></div>
        </div>
        <div class="info-card">
          <div class="i-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div><h4>Working Hours</h4><p>Monday – Saturday, 9:00 AM – 6:00 PM</p></div>
        </div>
      </div>

      <form class="form-card" id="rfq-form">
        <h3 style="font-size:21px;margin-bottom:6px">Request a Quote (RFQ)</h3>
        <p style="font-size:14px;margin-bottom:22px">Tell us about your component requirement and we will get back to you.</p>
        <div class="form-row">
          <div class="field"><label>Full Name</label><input type="text" placeholder="Your name" required /></div>
          <div class="field"><label>Company</label><input type="text" placeholder="Company name" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Email</label><input type="email" placeholder="you@company.com" required /></div>
          <div class="field"><label>Phone</label><input type="tel" placeholder="Phone number" /></div>
        </div>
        <div class="field">
          <label>Component / Requirement</label>
          <select>
            <option>Engine Components</option>
            <option>Transmission Parts</option>
            <option>Suspension &amp; Steering</option>
            <option>Sheet-Metal &amp; Fabricated</option>
            <option>Welded Assemblies</option>
            <option>Custom Components</option>
            <option>Other</option>
          </select>
        </div>
        <div class="field">
          <label>Message</label>
          <textarea placeholder="Describe your requirement, quantity and timeline..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center">
          Send RFQ
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
        <p class="form-msg" id="form-msg" style="display:none;margin-top:16px;color:var(--orange);font-weight:600;font-size:14px">
          Thank you — your request has been noted. We'll be in touch soon.
        </p>
      </form>
    </div>
  </section>

  <section style="padding-bottom:80px">
    <div class="container">
      <div class="ph map-band">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="ph-label">Map / Location Placeholder</span>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.getElementById('rfq-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const msg = document.getElementById('form-msg');
    if (msg) msg.style.display = 'block';
  });
</script>
