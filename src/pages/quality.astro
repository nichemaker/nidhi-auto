---
import Layout from '../layouts/Layout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Layout title="Quality — Nidhi Auto LLP" description="A disciplined, stage-by-stage quality system — from incoming material checks through final inspection and dispatch readiness." activePage="quality">

  <section class="page-header">
    <div class="container">
      <div class="crumb"><a href="/">Home</a> / <span>Quality</span></div>
      <h1>Quality &amp; Process Control</h1>
      <p>A disciplined, stage-by-stage quality system — from incoming material checks through final inspection and dispatch readiness.</p>
    </div>
  </section>

  <section class="process">
    <div class="container">
      <p class="eyebrow">Quality &amp; Process Control</p>
      <div class="proc-track">
        <div class="proc-step">
          <div class="proc-dashes"></div>
          <div class="proc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
          <div class="proc-circle">
            <span class="proc-badge">1</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
          </div>
          <h3>Incoming Checks</h3>
          <p>Raw material verification and dimensional checks to ensure quality at the source.</p>
        </div>
        <div class="proc-step">
          <div class="proc-dashes"></div>
          <div class="proc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
          <div class="proc-circle">
            <span class="proc-badge">2</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3>In-Process Inspection</h3>
          <p>Regular process inspections and monitoring to maintain consistency and accuracy.</p>
        </div>
        <div class="proc-step">
          <div class="proc-dashes"></div>
          <div class="proc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
          <div class="proc-circle">
            <span class="proc-badge">3</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
          </div>
          <h3>Final Inspection</h3>
          <p>Comprehensive inspection for functional, performance and dimensional checks before dispatch.</p>
        </div>
        <div class="proc-step">
          <div class="proc-circle">
            <span class="proc-badge">4</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          </div>
          <h3>Dispatch Readiness</h3>
          <p>Secure packing and documentation to ensure safe and timely deliveries.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sec-head"><p class="eyebrow">Our Commitment</p><h2>How We Maintain Quality</h2></div>
      <div class="feature-list">
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 8.7 8.7 21.3a1 1 0 0 1-1.4 0l-4.6-4.6a1 1 0 0 1 0-1.4L15.3 2.7a1 1 0 0 1 1.4 0l4.6 4.6a1 1 0 0 1 0 1.4Z"/><path d="m7.5 10.5 2 2M10.5 7.5l2 2M13.5 4.5l2 2M4.5 13.5l2 2"/></svg></div>
          <div>
            <h3>Dimensional Accuracy</h3>
            <p>Components checked against drawings to maintain strict tolerances and repeatability.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v5h5"/><path d="M9 13h6M9 17h4"/></svg></div>
          <div>
            <h3>Material Traceability</h3>
            <p>Incoming material verification and documentation to ensure the right grade and quality.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg></div>
          <div>
            <h3>Process Monitoring</h3>
            <p>In-process inspections keep production consistent and reduce variation across batches.</p>
          </div>
        </div>
        <div class="feature">
          <div class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg></div>
          <div>
            <h3>Final Inspection</h3>
            <p>Functional, performance and dimensional verification before any part leaves the facility.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />

</Layout>
